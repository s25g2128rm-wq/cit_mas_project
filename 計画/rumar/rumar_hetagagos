# -*- coding: utf-8 -*-
"""
噂拡散モデル (A-1: エージェント異質性版)

各エージェントが個別の拡散力 p_spread を持つ。
SPREADING_PROBABILITY_STD = 0 にすれば均質モデル(rumor_simulation.py)と一致する。

このモデルが開く問い:
- 「同じ平均拡散力でも、ばらつき(異質性)があると最終拡散率は変わるか?」
- 「初期拡散者として高 p_spread の人物を選ぶと、低 p_spread を選ぶより有利か?」
"""

import numpy as np
import matplotlib.pyplot as plt
import matplotlib.animation as animation
import datetime
import os

# シミュレーションパラメータの定義
WIDTH = 50
HEIGHT = 50
AGENTS_NUMBER = 300
INITIAL_SPREADER_NUMBER = 1
INTERACTION_RADIUS = 3.0

# === 異質性パラメータ ===
SPREADING_PROBABILITY_MEAN = 0.1   # 拡散確率の平均値
SPREADING_PROBABILITY_STD = 0.05   # 拡散確率のばらつき(0で均質モデル)

STIFLING_PROBABILITY = 0.05
SIMULATION_TIME = 200
AGENT_SPEED = 1.0

# 状態の定義
SUSCEPTIBLE = 0
SPREADER = 1
STIFLER = 2

# 色の定義
COLOR_SUSCEPTIBLE = 'blue'
COLOR_SPREADER = 'red'
COLOR_STIFLER = 'green'


# エージェントクラス
class Agent:
    def __init__(self, x, y, state, p_spread=None):
        self.x = x
        self.y = y
        self.state = state
        # p_spread が指定されていなければ正規分布から抽出してクリップ
        if p_spread is None:
            self.p_spread = max(0.0, min(1.0,
                np.random.normal(SPREADING_PROBABILITY_MEAN, SPREADING_PROBABILITY_STD)))
        else:
            self.p_spread = p_spread

    def move(self):
        angle = np.random.rand() * 2 * np.pi
        self.x += AGENT_SPEED * np.cos(angle)
        self.y += AGENT_SPEED * np.sin(angle)
        self.x = max(0, min(self.x, WIDTH))
        self.y = max(0, min(self.y, HEIGHT))


# シミュレーション初期化
def initialize_simulation():
    agents = []
    for _ in range(AGENTS_NUMBER):
        x = np.random.rand() * WIDTH
        y = np.random.rand() * HEIGHT
        agents.append(Agent(x, y, SUSCEPTIBLE))

    spreader_indices = np.random.choice(AGENTS_NUMBER, INITIAL_SPREADER_NUMBER, replace=False)
    for i in spreader_indices:
        agents[i].state = SPREADER

    return agents


# 拡散判定 (S → I): spreader 個別の p_spread を使う
def check_spreading(spreader, other):
    if other.state == SUSCEPTIBLE:
        distance = np.sqrt((spreader.x - other.x)**2 + (spreader.y - other.y)**2)
        if distance < INTERACTION_RADIUS and np.random.rand() < spreader.p_spread:
            other.state = SPREADER


# 飽き判定 (I → R): 接触ベース
def check_stifling(spreader, other):
    if other.state == SPREADER or other.state == STIFLER:
        distance = np.sqrt((spreader.x - other.x)**2 + (spreader.y - other.y)**2)
        if distance < INTERACTION_RADIUS and np.random.rand() < STIFLING_PROBABILITY:
            spreader.state = STIFLER


# シミュレーション実行
def run_simulation():
    count_susceptible = []
    count_spreader = []
    count_stifler = []
    history = []

    agents = initialize_simulation()

    # 初期 p_spread 分布を出力(参考)
    p_spread_values = [a.p_spread for a in agents]
    print(f'p_spread distribution: '
          f'mean={np.mean(p_spread_values):.3f}, '
          f'std={np.std(p_spread_values):.3f}, '
          f'min={np.min(p_spread_values):.3f}, '
          f'max={np.max(p_spread_values):.3f}')

    for frame in range(SIMULATION_TIME):
        # 移動
        for agent in agents:
            agent.move()

        # 相互作用判定
        for i, agent1 in enumerate(agents):
            if agent1.state == SPREADER:
                for j, agent2 in enumerate(agents):
                    if i == j:
                        continue
                    if agent1.state != SPREADER:
                        break
                    if agent2.state == SUSCEPTIBLE:
                        check_spreading(agent1, agent2)
                    else:
                        check_stifling(agent1, agent2)

        # 集計
        num_susceptible = sum(1 for a in agents if a.state == SUSCEPTIBLE)
        num_spreader    = sum(1 for a in agents if a.state == SPREADER)
        num_stifler     = sum(1 for a in agents if a.state == STIFLER)
        count_susceptible.append(num_susceptible)
        count_spreader.append(num_spreader)
        count_stifler.append(num_stifler)

        # コピー時に p_spread も保存(再ランダム化させない)
        agents_copy = [Agent(a.x, a.y, a.state, a.p_spread) for a in agents]
        history.append((agents_copy, count_susceptible[:], count_spreader[:], count_stifler[:]))

    # 最終的な p_spread の比較(高拡散力の人物が最終的にどの状態に多いか)
    final_agents = history[-1][0]
    final_S_p = [a.p_spread for a in final_agents if a.state == SUSCEPTIBLE]
    final_R_p = [a.p_spread for a in final_agents if a.state == STIFLER]
    if final_S_p:
        print(f'Final S group: mean p_spread = {np.mean(final_S_p):.3f} (n={len(final_S_p)})')
    if final_R_p:
        print(f'Final R group: mean p_spread = {np.mean(final_R_p):.3f} (n={len(final_R_p)})')

    return history


# 描画設定
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 6))

ax1.set_xlim(0, WIDTH)
ax1.set_ylim(0, HEIGHT)
ax1.set_aspect('equal')
ax1.set_title("Frame: 0")

ax2.set_xlim(0, SIMULATION_TIME)
ax2.set_ylim(0, AGENTS_NUMBER)
ax2.set_xlabel('Time')
ax2.set_ylabel('Number of Agents')
ax2.set_title('Number of Agents over Time (heterogeneous)')
line_susceptible, = ax2.plot([], [], label='Susceptible (unknown)', color=COLOR_SUSCEPTIBLE)
line_spreader,    = ax2.plot([], [], label='Spreader (active)',    color=COLOR_SPREADER)
line_stifler,     = ax2.plot([], [], label='Stifler (stopped)',    color=COLOR_STIFLER)
ax2.legend()
ax2.grid(True)

# シミュレーション実行
history = run_simulation()

# 初期状態描画
agents = history[0][0]
x = [a.x for a in agents]
y = [a.y for a in agents]
colors = [COLOR_SUSCEPTIBLE if a.state == SUSCEPTIBLE
          else COLOR_SPREADER if a.state == SPREADER
          else COLOR_STIFLER for a in agents]
scatter = ax1.scatter(x, y, c=colors, s=20)


def animate(frame):
    agents, count_susceptible, count_spreader, count_stifler = history[frame]
    x = [a.x for a in agents]
    y = [a.y for a in agents]
    colors = [COLOR_SUSCEPTIBLE if a.state == SUSCEPTIBLE
              else COLOR_SPREADER if a.state == SPREADER
              else COLOR_STIFLER for a in agents]
    scatter.set_offsets(np.c_[x, y])
    scatter.set_facecolor(colors)

    ax1.set_title(f"Frame: {frame}")
    line_susceptible.set_data(range(len(count_susceptible)), count_susceptible)
    line_spreader.set_data(range(len(count_spreader)), count_spreader)
    line_stifler.set_data(range(len(count_stifler)), count_stifler)

    return scatter, line_susceptible, line_spreader, line_stifler,


ani = animation.FuncAnimation(fig, animate, frames=SIMULATION_TIME, blit=False, repeat=False)

plt.tight_layout()
plt.show()

# GIF保存
now = datetime.datetime.now()
filename = 'rumor_heterogeneous_' + now.strftime('%Y%m%d_%H%M%S') + '.gif'
gif_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), filename)
print('Now Saving...', end='', flush=True)
ani.save(gif_path, writer="pillow", fps=10)
print('Done.')